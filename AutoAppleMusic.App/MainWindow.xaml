<Window x:Class="AutoAppleMusic.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutoAppleMusic.App"
        mc:Ignorable="d"
        Title="Auto Apple Music"
        Width="500"
        Height="760"
        MinWidth="500"
        MinHeight="760"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift SemiCondensed"
        Background="#081219"
        Icon="pack://application:,,,/Assets/app-icon.ico"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush"
                             StartPoint="0.08,0"
                             EndPoint="0.92,1">
            <GradientStop Color="#07131B" Offset="0" />
            <GradientStop Color="#0B2230" Offset="0.52" />
            <GradientStop Color="#13384A" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ToggleOffBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#FF9B61" Offset="0" />
            <GradientStop Color="#F66D53" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ToggleOnBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#69E7D8" Offset="0" />
            <GradientStop Color="#2F9DB8" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="42"
                          ShadowDepth="14"
                          Opacity="0.34"
                          Color="#04070A" />

        <Style x:Key="GlassPanelStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Background" Value="#4A11202B" />
            <Setter Property="BorderBrush" Value="#22FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border" BasedOn="{StaticResource GlassPanelStyle}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="#3A10202B" />
        </Style>

        <Style x:Key="ToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="266" />
            <Setter Property="Height" Value="266" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#FFF9F3E8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="{StaticResource ToggleOffBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root"
                              Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform />
                            </Grid.RenderTransform>

                            <Border x:Name="Glow"
                                    Margin="18"
                                    CornerRadius="120"
                                    Background="#30FF8A62"
                                    Opacity="0.92">
                                <Border.Effect>
                                    <BlurEffect Radius="26" />
                                </Border.Effect>
                            </Border>

                            <Border x:Name="Shell"
                                    CornerRadius="133"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#44FFFFFF"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="34"
                                                      ShadowDepth="16"
                                                      Opacity="0.32"
                                                      Color="#05090D" />
                                </Border.Effect>

                                <Grid>
                                    <Ellipse Margin="24"
                                             Fill="#16FFFFFF"
                                             Stroke="#18FFFFFF"
                                             StrokeThickness="1" />

                                    <Ellipse Margin="36"
                                             Fill="#0F081219"
                                             Stroke="#23FFFFFF"
                                             StrokeThickness="1" />

                                    <Ellipse Margin="26"
                                             Width="154"
                                             Height="82"
                                             VerticalAlignment="Top"
                                             Fill="#2DFFFFFF">
                                        <Ellipse.Effect>
                                            <BlurEffect Radius="20" />
                                        </Ellipse.Effect>
                                    </Ellipse>

                                    <Grid Width="118"
                                          Height="118"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                        <Path x:Name="PlayIcon"
                                              Width="88"
                                              Height="102"
                                              Stretch="Fill"
                                              Fill="#FFF9F3E8"
                                              Data="M 6 0 L 6 102 L 90 51 Z" />

                                        <Grid x:Name="PauseIcon"
                                              Visibility="Collapsed">
                                            <Border Width="30"
                                                    Height="108"
                                                    CornerRadius="15"
                                                    HorizontalAlignment="Left"
                                                    Background="#FFF9F3E8" />

                                            <Border Width="30"
                                                    Height="108"
                                                    CornerRadius="15"
                                                    HorizontalAlignment="Right"
                                                    Background="#FFF9F3E8" />
                                        </Grid>
                                    </Grid>

                                    <StackPanel Margin="0,0,0,28"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom">
                                        <TextBlock x:Name="PrimaryActionText"
                                                   HorizontalAlignment="Center"
                                                   FontSize="23"
                                                   FontWeight="SemiBold"
                                                   Text="Arm automation" />

                                        <TextBlock x:Name="SecondaryActionText"
                                                   Margin="0,6,0,0"
                                                   HorizontalAlignment="Center"
                                                   FontSize="13"
                                                   Foreground="#CCFFF7EC"
                                                   Text="Apple Music will take the fallback lane." />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Shell" Property="BorderBrush" Value="#6EFFFFFF" />
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.6" />
                            </Trigger>

                            <DataTrigger Binding="{Binding IsAutomationEnabled}" Value="True">
                                <Setter Property="Background" Value="{StaticResource ToggleOnBrush}" />
                                <Setter TargetName="Glow" Property="Background" Value="#2469E7D8" />
                                <Setter TargetName="PlayIcon" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="PauseIcon" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PrimaryActionText" Property="Text" Value="Automation live" />
                                <Setter TargetName="SecondaryActionText" Property="Text" Value="Click once to pause the handoff." />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="{StaticResource WindowBackgroundBrush}" />

        <Ellipse Width="360"
                 Height="360"
                 Margin="-70,-90,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="#36FF9E63">
            <Ellipse.Effect>
                <BlurEffect Radius="84" />
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="320"
                 Height="320"
                 Margin="0,0,-80,-100"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="#2F6DE6DA">
            <Ellipse.Effect>
                <BlurEffect Radius="94" />
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="240"
                 Height="240"
                 Margin="0,210,-80,0"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Fill="#18FFFFFF">
            <Ellipse.Effect>
                <BlurEffect Radius="56" />
            </Ellipse.Effect>
        </Ellipse>

        <Border Margin="26"
                Padding="28"
                CornerRadius="34"
                Background="#CC0D1E29"
                BorderBrush="#2DFFFFFF"
                BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="74"
                                Height="74"
                                CornerRadius="24"
                                Background="#14FFFFFF"
                                BorderBrush="#28FFFFFF"
                                BorderThickness="1">
                            <Image Margin="10"
                                   Source="pack://application:,,,/Assets/logo-mark.png"
                                   Stretch="Uniform" />
                        </Border>

                        <StackPanel Width="248"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock FontSize="31"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF8F2E8"
                                       Text="Auto Apple Music" />

                            <TextBlock Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="#B6CCD6DA"
                                       TextWrapping="Wrap"
                                       Text="A softer desktop soundtrack that knows when YouTube and everything else should take over." />
                        </StackPanel>
                    </StackPanel>

                    <Border x:Name="StatePill"
                            DockPanel.Dock="Right"
                            Padding="16,9"
                            Margin="12,8,0,0"
                            CornerRadius="16"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="#18FFFFFF"
                            BorderBrush="#24FFFFFF"
                            BorderThickness="1">
                        <Grid>
                            <TextBlock x:Name="PausedPillText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFFC7A2"
                                       Text="PAUSED">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutomationEnabled}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock x:Name="LivePillText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FFD4FFF6"
                                       Text="LIVE"
                                       Visibility="Collapsed">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutomationEnabled}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <TextBlock x:Name="BusyPillText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF9F3E8"
                                       Text="SYNCING"
                                       Visibility="Collapsed">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#18FFFFFF" />
                                <Setter Property="BorderBrush" Value="#24FFFFFF" />

                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAutomationEnabled}" Value="True">
                                        <Setter Property="Background" Value="#214FE7D9" />
                                        <Setter Property="BorderBrush" Value="#4E8BFFF4" />
                                    </DataTrigger>

                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <Setter Property="Background" Value="#22FFF3E6" />
                                        <Setter Property="BorderBrush" Value="#35FFFFFF" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </DockPanel>

                <StackPanel Grid.Row="1" Margin="0,28,0,0">
                    <TextBlock FontSize="36"
                               FontWeight="SemiBold"
                               Foreground="#FFF8F2E8"
                               TextWrapping="Wrap"
                               Text="Your fallback soundtrack, made effortless." />

                    <TextBlock Margin="0,12,0,0"
                               FontSize="15"
                               LineHeight="22"
                               Foreground="#B2D0D8DC"
                               TextWrapping="Wrap"
                               Text="One tap arms the loop. When outside audio shows up, Apple Music slips away. When things go quiet, it comes back without you hunting for the play button." />
                </StackPanel>

                <Button Grid.Row="2"
                        Margin="0,30,0,0"
                        HorizontalAlignment="Center"
                        Style="{StaticResource ToggleButtonStyle}"
                        Command="{Binding ToggleAutomationCommand}" />

                <Border Grid.Row="3"
                        Margin="0,30,0,0"
                        Style="{StaticResource GlassPanelStyle}">
                    <StackPanel>
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#FFB7C7CC"
                                   Text="LIVE STATUS" />

                        <TextBlock Margin="0,10,0,0"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF9F2E8"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusLine}" />

                        <TextBlock Margin="0,10,0,0"
                                   FontSize="15"
                                   LineHeight="21"
                                   Foreground="#B9D0D8DD"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusDetail}" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="4" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FFFAB280"
                                       Text="OTHER AUDIO ARRIVES" />

                            <TextBlock Margin="0,10,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF9F2E8"
                                       TextWrapping="Wrap"
                                       Text="Apple Music steps back immediately." />

                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="#B5D0D8DD"
                                       TextWrapping="Wrap"
                                       Text="YouTube, tabs, and other apps can take the room without competing audio." />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#FF8EF9EA"
                                       Text="THE ROOM GOES QUIET" />

                            <TextBlock Margin="0,10,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF9F2E8"
                                       TextWrapping="Wrap"
                                       Text="Apple Music finds its way back." />

                            <TextBlock Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="#B5D0D8DD"
                                       TextWrapping="Wrap"
                                       Text="If the app was closed, the automation can reopen it and resume the last playback session." />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="5"
                        Margin="0,18,0,0"
                        Style="{StaticResource InfoCardStyle}"
                        Background="#3716252E">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40"
                                Height="40"
                                Margin="0,0,14,0"
                                CornerRadius="14"
                                Background="#1FFFD39B"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#FFF8F2E8"
                                       Text="II" />
                        </Border>

                        <StackPanel Width="350">
                            <TextBlock FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF9F2E8"
                                       Text="Manual pauses stay respected." />

                            <TextBlock Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="#B5D0D8DD"
                                       TextWrapping="Wrap"
                                       Text="If you pause Apple Music yourself, the app waits for a fresh outside-audio cycle before it resumes anything for you." />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
